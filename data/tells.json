  "constructions": [
    {"id": "not_just_but", "re": "(?i)\\bnot (?:just|only|merely)\\b[^.!?\\n]{0,60}?\\bbut\\b", "w": 3, "example": "It's not just a tool, but a philosophy."},
    {"id": "its_not_x_its_y", "re": "(?i)\\bit'?s not (?:about )?[^.!?\\n]{2,40}[.;,—–-]\\s*it'?s\\b", "w": 4, "example": "It's not about speed. It's about trust."},
    {"id": "isnt_just_a", "re": "(?i)\\bisn'?t just an?\\b", "w": 2.5, "example": "This isn't just a launch."},
    {"id": "more_than_just", "re": "(?i)\\bmore than just an?\\b", "w": 2, "example": "More than just a newsletter."},
    {"id": "no_x_no_y_just_z", "re": "(?i)\\bno \\w+[,.;] no \\w+[,.;] just \\w+", "w": 4, "example": "No fluff, no filler, just results."},
    {"id": "no_fluff", "re": "(?i)\\bno (?:fluff|jargon|gimmicks|strings attached|catch)\\b", "w": 3, "example": "No fluff. Real strategies."},
    {"id": "whether_youre", "re": "(?i)\\bwhether you'?re\\b", "w": 2.5, "example": "Whether you're a beginner or a pro..."},
    {"id": "from_x_to_y_range", "re": "(?i)\\bfrom (?:the )?\\w[^.!?\\n]{3,45}? to (?:the )?\\w", "w": 1, "cap": 2, "min_hits": 2, "example": "From the boardroom to the breakroom (false range; only counts when repeated)"},
    {"id": "heres_the", "re": "(?im)^here'?s (?:the|what|why|how)\\b", "w": 2, "example": "Here's the thing:"},
    {"id": "full_stop", "re": "(?i)\\bfull stop\\.", "w": 2, "example": "This matters. Full stop."},
    {"id": "thats_where_comes_in", "re": "(?i)\\bthat'?s where [^.!?\\n]{2,30} comes? in\\b", "w": 4, "example": "That's where WidgetCo comes in."},
    {"id": "say_goodbye", "re": "(?i)\\bsay goodbye to\\b", "w": 3, "example": "Say goodbye to messy spreadsheets."},
    {"id": "say_hello", "re": "(?i)\\bsay hello to\\b", "w": 2.5, "example": "Say hello to effortless invoicing."},
    {"id": "gone_are_the_days", "re": "(?i)\\bgone are the days\\b", "w": 3, "example": "Gone are the days of manual entry."},
    {"id": "in_a_world", "re": "(?i)\\bin a world (?:where|of)\\b", "w": 3, "example": "In a world where attention is currency..."},
    {"id": "enter_product", "re": "(?m)^Enter [A-Z][\\w-]+\\.", "w": 3, "example": "Enter Shotbox."},
    {"id": "imagine_opener", "re": "(?im)^imagine\\b", "w": 2, "example": "Imagine never losing a screenshot again."},
    {"id": "picture_this", "re": "(?i)\\bpicture this\\b", "w": 2.5, "example": "Picture this: it's Monday morning..."},
    {"id": "the_best_part", "re": "(?i)(?:the )?best part\\?", "w": 2.5, "example": "The best part? It's free."},
    {"id": "the_result_q", "re": "(?im)^the result\\?", "w": 2.5, "example": "The result? A 40% lift."},
    {"id": "sound_familiar", "re": "(?i)\\bsound familiar\\?", "w": 2.5, "example": "Sound familiar?"},
    {"id": "lets_be_honest", "re": "(?i)\\blet'?s (?:be honest|be real|face it)\\b", "w": 2, "example": "Let's be honest: nobody reads reports."},
    {"id": "pro_tip", "re": "(?im)^pro tip:", "w": 2, "example": "Pro tip: batch your screenshots."},
    {"id": "hot_take", "re": "(?im)^(?:hot take|unpopular opinion):", "w": 2.5, "example": "Hot take: (burned opener)"},
    {"id": "nobody_talks_about", "re": "(?i)\\b(?:nobody|no one) (?:talks about|tells you)\\b", "w": 2.5, "example": "What nobody tells you about churn."},
    {"id": "i_wish_someone_told_me", "re": "(?i)\\bi wish someone had told me\\b", "w": 2, "example": "burned confessional opener"},
    {"id": "aphorism_x_is_the_y_of_z", "re": "(?i)\\b\\w+ is the (?!capital|city|home|ceo|founder|president|author|mother|father|son|daughter|part|end|rest|name|owner|first|last|only)\\w+ of \\w+", "w": 1.5, "cap": 2, "example": "Consistency is the currency of trust."},
    {"id": "not_because_but_because", "re": "(?i)\\bnot because [^.!?\\n]{2,40} but because\\b", "w": 2.5, "example": "Not because it's easy, but because it's right."},
    {"id": "bold_header_bullet", "re": "(?m)^\\s*[-*•]\\s*\\*\\*[^*\\n]{2,40}:?\\*\\*", "w": 3, "cap": 3, "example": "- **Performance:** improved by..."},
    {"id": "arrow_emoji_bullet", "re": "(?m)^\\s*(?:→|➜|✅|🔥|🚀|💡|✨|👉|🎯|⚡)", "w": 1.5, "cap": 4, "min_hits": 2, "example": "🚀 Launch  ✅ Profit"},
    {"id": "colon_how_why_headline", "re": "(?im)^[^\\n:]{8,60}: (?:here'?s (?:how|why)|a (?:guide|thread))", "w": 2.5, "example": "Scaling to 10k users: here's how"},
    {"id": "stay_tuned", "re": "(?i)\\bstay tuned\\b", "w": 2, "example": "Stay tuned for more updates."},
    {"id": "exciting_times", "re": "(?i)\\bexciting (?:times|things) (?:ahead|to come)\\b", "w": 3, "example": "Exciting times ahead!"},
    {"id": "the_future_is", "re": "(?i)\\bthe future (?:is|looks) (?:bright|now|here)\\b", "w": 3, "example": "The future is bright."},
    {"id": "only_time_will_tell", "re": "(?i)\\bonly time will tell\\b", "w": 2.5, "example": "generic non-ending"},
    {"id": "at_the_end_of_the_day_dbl", "re": "(?i)\\bat the end of the day\\b", "w": 1, "cap": 2, "min_hits": 2, "example": "human-common; only counts twice+"},
    {"id": "engagement_bait_close", "re": "(?im)(?:^|\\b)(?:thoughts\\?|agree\\?|who else\\?|am i wrong\\?|let me know in the comments|drop a \\w+ below|smash that)\\s*$", "w": 3, "example": "Thoughts?"},
    {"id": "dm_me_bait", "re": "(?i)\\bdm me [\"'“”]?\\w+[\"'“”]? (?:for|to)\\b", "w": 2.5, "example": "DM me 'GROWTH' for the playbook"},
    {"id": "chatbot_artifact", "re": "(?i)\\b(?:i hope this helps|as an ai|as of my last|let me know if you'?d like|would you like me to|here is an? \\w+ of)\\b", "w": 5, "example": "pasted chatbot correspondence"},
    {"id": "certainly_opener", "re": "(?m)^(?:Certainly|Of course|Great question)[!.,]", "w": 5, "example": "chatbot response pasted as content"},
    {"id": "knowledge_cutoff", "re": "(?i)\\b(?:as of (?:my|the) (?:last|latest) (?:update|training)|based on available information|while specific details are (?:limited|scarce))\\b", "w": 5, "example": "cutoff disclaimer"},
    {"id": "in_todays", "re": "(?i)\\bin today'?s [\\w-]+ (?:world|landscape|market|environment|economy|age)\\b", "w": 3, "example": "In today's competitive market..."}
  ],
  "metrics": {
    "em_dash_per_100w": {"warn": 0.8, "bad": 1.5, "w_warn": 2, "w_bad": 5, "note": "GPT-4.1 emits 10.6/1k words vs human mean 3.2, but human range 0.3-17 overlaps everything (arXiv 2603.27006) — cluster evidence only, hence modest weights"},
    "sent_cv": {"warn_below": 0.5, "bad_below": 0.36, "w_warn": 3, "w_bad": 6, "min_sentences": 6, "note": "burstiness: coefficient of variation of sentence length; RLHF models write metronomically uniform sentences"},
    "para_cv": {"warn_below": 0.28, "w_warn": 3, "min_paras": 4, "note": "paragraph-length uniformity"},
    "avg_sent_len": {"warn_above": 26, "w_warn": 2},
    "triad_density_per_300w": {"warn": 3, "w_warn": 4, "note": "rule-of-three: 'A, B, and C' constructions"},
    "staccato_run": {"run_len": 3, "max_words": 4, "w": 3, "cap": 2, "note": "3+ consecutive sentences of <=4 words = manufactured drama"},
    "hedge_density_per_100w": {"warn": 3.5, "w_warn": 2.5, "hedges": ["might", "may", "could", "perhaps", "potentially", "arguably", "seemingly", "it seems", "tends to", "can be seen as"]},
    "emoji_per_100w": {"warn": 1.5, "w_warn": 2, "note": "platform-sensitive; IG/TikTok tolerate more"},
    "hashtag_count": {"warn": 4, "w_warn": 3, "note": "2026 norms: IG caps ~3, X organic ~0-1, LinkedIn 0-3"},
    "bold_spans_per_200w": {"warn": 3, "w_warn": 3},
    "title_case_headings": {"w_each": 1.5, "cap": 3},
    "exclam_para_uniformity": {"w": 2, "note": "every paragraph ends with ! -> mechanical enthusiasm"},
    "both_sides_marker": {"w": 2, "a": "on one hand", "b": "on the other"},
    "curly_quotes": {"w": 0.5, "cap": 1, "note": "weak alone: macOS/Word/Docs auto-curl; counts once, cluster evidence only"}
  },
  "human_signals": {
    "note": "REPORTED as texture checklist, never subtracted from the AI score (gameable — Jakesch PNAS 2023). Their ABSENCE in a long personal-register post is itself worth reporting.",
    "patterns": [
      {"id": "first_person_specific", "re": "(?i)\\bI (?:spent|paid|bought|broke|forgot|missed|counted|drove|texted|emailed|called)\\b", "label": "first-person concrete action"},
      {"id": "exact_number_units", "re": "(?i)\\b\\d+(?:\\.\\d+)?\\s?(?:%|\\$|€|£|₦|₹|kg|lb|lbs|km|mi|hrs?|hours?|minutes?|days?|weeks?|users?|orders?|units?|copies|dkk|vnd|r\\$)\\b|\\$\\d+|£\\d+|€\\d+", "label": "number with unit/currency"},
      {"id": "temporal_anchor", "re": "(?i)\\b(?:yesterday|this morning|last (?:week|night|tuesday|month)|on (?:mon|tues|wednes|thurs|fri|satur|sun)day|at \\d{1,2}(?::\\d{2})?\\s?(?:am|pm))\\b", "label": "temporal anchor"},
      {"id": "named_specific", "re": "\\b(?:[A-Z][a-z]+ (?:Street|Ave|Road|Blvd|County|Diner|Cafe|Market))\\b", "label": "named place"},
      {"id": "self_correction", "re": "(?i)\\((?:ok|okay|fine|edit|update|wait)[,:]? [^)]{3,60}\\)", "label": "parenthetical self-correction"},
      {"id": "informal_marker", "re": "(?i)\\b(?:gonna|gotta|kinda|sorta|tbh|idk|btw|lol|ngl|imo|fwiw)\\b", "label": "informal register marker"},
      {"id": "mixed_feelings", "re": "(?i)\\b(?:i'?m (?:torn|split|not sure how i feel)|mixed feelings|part of me)\\b", "label": "unresolved ambivalence"}
    ]
  },
  "false_positive_guard": {
    "note": "Never flag inside quotations or code blocks; em dashes alone are journalism-normal; curly quotes alone are autoformat; one 'however' is not a tell; formal vocabulary in academic register is not a tell. Clusters convict, single hits do not.",
    "quote_spans_ignored": true,
    "code_blocks_ignored": true
  }
}
