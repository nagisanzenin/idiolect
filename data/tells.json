{
  "version": 1,
  "note": "Machine-readable AI-tell lexicon for idiolect.py scan. Weights are per-hit points; scoring normalizes per 100 words with a cluster multiplier. Sources: Wikipedia Signs of AI writing (WikiProject AI Cleanup), Kobak et al. Science Advances 2025 excess-vocabulary data, GPTZero/Pangram/Binoculars public feature docs, arXiv 2603.27006 em-dash study. 'era' tags which model generation a tell fingerprints: gpt4 (2023-24 classic slop), gpt5 (2025-26 residue), grok, claude, all. IMPORTANT: this is a LINTER for your own drafts, not a detector for accusing people. Human-signal patterns are REPORTED, never subtracted from the score (first-person and contractions are gameable heuristics — Jakesch et al., PNAS 2023).",
  "scoring": {
    "per_term_cap": 2,
    "per_construction_cap": 3,
    "cluster_multipliers": {"3": 1.2, "4": 1.35},
    "normalize_to_words": 200,
    "min_words_for_stats": 60,
    "bands": [{"max": 15, "band": "clean"}, {"max": 40, "band": "suspect"}, {"max": 100, "band": "slop"}]
  },
